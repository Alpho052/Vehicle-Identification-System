<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<VBox spacing="0" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.vehicle.vehicleidentificationsystem.controller.PoliceController"
      style="-fx-background-color: #f5f7fa;">

    <!-- Header -->
    <HBox style="-fx-background-color: linear-gradient(to right, #b71c1c, #c62828); -fx-padding: 15 20 15 20;" alignment="CENTER_LEFT" spacing="15">
        <Text text="Vehicle Identification System" style="-fx-fill: white; -fx-font-size: 18; -fx-font-weight: bold;">
            <font><Font name="System Bold" size="18"/></font>
        </Text>
        <Rectangle width="2" height="30" style="-fx-fill: rgba(255,255,255,0.3);" arcWidth="1" arcHeight="1"/>
        <Text text="Police Portal" style="-fx-fill: #ef9a9a; -fx-font-size: 14;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox alignment="CENTER_RIGHT" spacing="15">
            <Label text="Welcome, " style="-fx-text-fill: white; -fx-font-size: 13;"/>
            <Label fx:id="welcomeLabel" style="-fx-text-fill: #ffd54f; -fx-font-size: 13; -fx-font-weight: bold;"/>
            <Button text="Logout" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 5; -fx-padding: 5 15 5 15; -fx-cursor: hand;"/>
        </HBox>
    </HBox>

    <!-- Menu Bar -->
    <MenuBar style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
        <Menu text="File">
            <MenuItem text="Exit" onAction="#handleExit"/>
        </Menu>
        <Menu text="Police">
            <MenuItem text="Add Report" onAction="#handleAddReport"/>
            <MenuItem text="Add Violation" onAction="#handleAddViolation"/>
            <MenuItem text="Delete Report" onAction="#handleDeleteReport"/>
            <MenuItem text="Mark Paid" onAction="#handleMarkViolationPaid"/>
            <MenuItem text="Refresh" onAction="#handleRefresh"/>
        </Menu>
        <Menu text="Help">
            <MenuItem text="About"/>
        </Menu>
    </MenuBar>

    <TabPane VBox.vgrow="ALWAYS" style="-fx-padding: 0 20 20 20; -fx-tab-min-height: 40;">

        <!-- Reports Tab -->
        <Tab text="Police Reports" closable="false">
            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox spacing="20" style="-fx-padding: 20;">

                    <!-- Add Report Form -->
                    <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                        <Label text="File Police Report" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #c62828;">
                            <effect><DropShadow offsetX="1" offsetY="1" radius="3" color="#c6282830"/></effect>
                        </Label>

                        <GridPane hgap="15" vgap="12">
                            <Label text="Vehicle:" style="-fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="vehicleCombo" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="300" promptText="Select a vehicle"/>

                            <Label text="Report Type:" style="-fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="reportTypeCombo" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="150" promptText="Select type"/>

                            <Label text="Description:" style="-fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextArea fx:id="reportDescArea" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="450" prefHeight="80" promptText="Detailed description of incident"/>

                            <Label text="Location:" style="-fx-font-weight: bold;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <TextField fx:id="locationField" GridPane.rowIndex="3" GridPane.columnIndex="1" prefWidth="300" promptText="Incident location"/>

                            <Label text="Case Number:" style="-fx-font-weight: bold;" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <TextField fx:id="caseNumberField" GridPane.rowIndex="4" GridPane.columnIndex="1" prefWidth="200" promptText="Unique case number"/>

                            <Button text="File Report" onAction="#handleAddReport" GridPane.rowIndex="5" GridPane.columnIndex="1" style="-fx-background-color: #c62828; -fx-text-fill: white; -fx-padding: 10 20 10 20; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;">
                                <effect><DropShadow offsetX="2" offsetY="2" radius="5" color="#c62828"/></effect>
                            </Button>
                        </GridPane>
                    </VBox>

                    <!-- Reports Table -->
                    <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                        <Label text="All Reports" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #c62828;"/>
                        <TableView fx:id="reportsTable" prefHeight="300" style="-fx-background-radius: 8;"/>
                        <Button text="Delete Selected Report" onAction="#handleDeleteReport" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-padding: 8 20 8 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    </VBox>

                </VBox>
            </ScrollPane>
        </Tab>

        <!-- Violations Tab -->
        <Tab text="Violations" closable="false">
            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox spacing="20" style="-fx-padding: 20;">

                    <!-- Add Violation Form -->
                    <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                        <Label text="Record Violation" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #c62828;"/>

                        <GridPane hgap="15" vgap="12">
                            <Label text="Vehicle:" style="-fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="vehicleComboViolation" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="300" promptText="Select a vehicle"/>

                            <Label text="Violation Date:" style="-fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <DatePicker fx:id="violationDatePicker" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="200"/>

                            <Label text="Violation Type:" style="-fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField fx:id="violationTypeField" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="250" promptText="e.g., Speeding, Reckless Driving"/>

                            <Label text="Fine Amount (M):" style="-fx-font-weight: bold;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <TextField fx:id="fineAmountField" GridPane.rowIndex="3" GridPane.columnIndex="1" prefWidth="150" promptText="0.00"/>

                            <Label text="Points:" style="-fx-font-weight: bold;" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <TextField fx:id="pointsField" GridPane.rowIndex="4" GridPane.columnIndex="1" prefWidth="100" promptText="0"/>

                            <Button text="Record Violation" onAction="#handleAddViolation" GridPane.rowIndex="5" GridPane.columnIndex="1" style="-fx-background-color: #ff9800; -fx-text-fill: white; -fx-padding: 10 20 10 20; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;">
                                <effect><DropShadow offsetX="2" offsetY="2" radius="5" color="#ff9800"/></effect>
                            </Button>
                        </GridPane>
                    </VBox>

                    <!-- Violations Table -->
                    <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                        <Label text="All Violations" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #c62828;"/>
                        <TableView fx:id="violationsTable" prefHeight="300" style="-fx-background-radius: 8;"/>
                        <Button text="Mark Selected as Paid" onAction="#handleMarkViolationPaid" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 8 20 8 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    </VBox>

                </VBox>
            </ScrollPane>
        </Tab>

    </TabPane>

    <Label fx:id="statusLabel" style="-fx-text-fill: #27ae60; -fx-padding: 10;"/>
</VBox>