<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<VBox spacing="0" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.vehicle.vehicleidentificationsystem.controller.CustomerController"
      style="-fx-background-color: #f5f7fa;">

    <!-- Header -->
    <HBox style="-fx-background-color: linear-gradient(to right, #0c1445, #1a237e); -fx-padding: 15 20 15 20;" alignment="CENTER_LEFT" spacing="15">
        <Text text="Vehicle Identification System" style="-fx-fill: white; -fx-font-size: 18; -fx-font-weight: bold;">
            <font><Font name="System Bold" size="18"/></font>
        </Text>
        <Rectangle width="2" height="30" style="-fx-fill: rgba(255,255,255,0.3);" arcWidth="1" arcHeight="1"/>
        <Text text="Customer Portal" style="-fx-fill: #aab6fe; -fx-font-size: 14;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox alignment="CENTER_RIGHT" spacing="15">
            <Label text="Welcome, " style="-fx-text-fill: white; -fx-font-size: 13;"/>
            <Label fx:id="welcomeLabel" style="-fx-text-fill: #ffd54f; -fx-font-size: 13; -fx-font-weight: bold;"/>
            <Button text="Logout" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 5; -fx-padding: 5 15 5 15; -fx-cursor: hand;"/>
        </HBox>
    </HBox>

    <!-- Menu Bar -->
    <MenuBar style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
        <Menu text="File">
            <MenuItem text="Exit" onAction="#handleExit"/>
        </Menu>
        <Menu text="Profile">
            <MenuItem text="My Profile" onAction="#handleEditProfile"/>
            <MenuItem text="Add Vehicle" onAction="#handleAddVehicle"/>
            <MenuItem text="Refresh" onAction="#handleRefresh"/>
        </Menu>
        <Menu text="Help">
            <MenuItem text="About"/>
        </Menu>
    </MenuBar>

    <TabPane VBox.vgrow="ALWAYS" style="-fx-padding: 0 20 20 20; -fx-tab-min-height: 40;">

        <!-- Profile Tab -->
        <Tab text="My Profile" closable="false">
            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox spacing="20" style="-fx-padding: 20;">
                    <Label text="Personal Information" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1a237e;">
                        <effect><DropShadow offsetX="1" offsetY="1" radius="3" color="#1a237e30"/></effect>
                    </Label>

                    <GridPane hgap="20" vgap="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                        <Label text="Full Name:" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Label fx:id="customerNameLabel" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-text-fill: #555;"/>

                        <Label text="Email:" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Label fx:id="emailLabel" GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-text-fill: #555;"/>

                        <Label text="Phone:" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <Label fx:id="phoneLabel" GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-text-fill: #555;"/>

                        <Label text="Address:" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <Label fx:id="addressLabel" GridPane.rowIndex="3" GridPane.columnIndex="1" style="-fx-text-fill: #555;" wrapText="true"/>

                        <Label text="License Number:" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <Label fx:id="licenseNumberLabel" GridPane.rowIndex="4" GridPane.columnIndex="1" style="-fx-text-fill: #555;"/>

                        <Label text="Date of Birth:" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                        <Label fx:id="dobLabel" GridPane.rowIndex="5" GridPane.columnIndex="1" style="-fx-text-fill: #555;"/>
                    </GridPane>

                    <Button text="Edit Profile" onAction="#handleEditProfile" style="-fx-background-color: #1a237e; -fx-text-fill: white; -fx-padding: 10 25 10 25; -fx-background-radius: 8; -fx-cursor: hand;">
                        <effect><DropShadow offsetX="2" offsetY="2" radius="5" color="#1a237e"/></effect>
                    </Button>
                </VBox>
            </ScrollPane>
        </Tab>

        <!-- Vehicles Tab -->
        <Tab text="My Vehicles" closable="false">
            <VBox spacing="15" style="-fx-padding: 20;">
                <HBox spacing="15">
                    <Button text="Add Vehicle" onAction="#handleAddVehicle" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 10 20 10 20; -fx-background-radius: 6; -fx-cursor: hand;">
                        <effect><DropShadow offsetX="2" offsetY="2" radius="5" color="#27ae60"/></effect>
                    </Button>
                    <Button text="Edit Selected" onAction="#handleEditVehicle" style="-fx-background-color: #ff9800; -fx-text-fill: white; -fx-padding: 10 20 10 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    <Button text="Delete Selected" onAction="#handleDeleteVehicle" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-padding: 10 20 10 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    <Button text="Refresh" onAction="#handleRefresh" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 10 20 10 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                </HBox>
                <TableView fx:id="vehiclesTable" prefHeight="400" style="-fx-background-radius: 8;"/>
            </VBox>
        </Tab>

        <!-- Support Queries Tab -->
        <Tab text="Support Queries" closable="false">
            <VBox spacing="15" style="-fx-padding: 20;">
                <Label text="Customer Support" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1a237e;"/>

                <GridPane hgap="15" vgap="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 4);">
                    <Label text="Vehicle:" style="-fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="vehicleCombo" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="350" promptText="Select a vehicle" style="-fx-padding: 5;"/>

                    <Label text="Your Question:" style="-fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextArea fx:id="queryTextArea" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="500" prefHeight="80" promptText="Describe your issue or question here..." style="-fx-padding: 8;"/>

                    <Button text="Submit Query" onAction="#handleSubmitQuery" GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 10 20 10 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                </GridPane>

                <Separator/>

                <Label text="My Query History" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1a237e;"/>
                <TableView fx:id="queriesTable" prefHeight="300" style="-fx-background-radius: 8;"/>

                <Label fx:id="statusLabel" style="-fx-text-fill: #27ae60; -fx-padding: 5;"/>
            </VBox>
        </Tab>

    </TabPane>
</VBox>